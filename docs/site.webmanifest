---
---
{
  "name": "{{ site.app_name }}",
  "short_name": "{{ site.app_name }}",
  "icons": [
    { "src": "{{ site.baseurl }}/assets/favicon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "{{ site.baseurl }}/{{ site.app_icon }}", "sizes": "1024x1024", "type": "image/png" }
  ],
  "theme_color": "{{ site.accent_color }}",
  "background_color": "#0C0C0F",
  "display": "standalone"
}
